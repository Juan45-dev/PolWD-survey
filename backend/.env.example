# Copy to .env and fill in values. Do not commit .env.

MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=pwd_survey
PORT=5175

# Required for GET /api/admin/responses (reporting). Use a long random string in production.
ADMIN_API_KEY=

# Browser origins allowed to call the API (comma-separated, no spaces). Include every site that hosts the survey.
# Local static server on 8080:
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# GitHub Pages example (add your real user/repo origin):
# CORS_ORIGINS=https://your-user.github.io,http://localhost:8080
